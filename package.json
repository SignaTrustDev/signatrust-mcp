{
  "name": "@signatrust/mcp-server",
  "version": "0.1.2",
  "description": "Model Context Protocol server for the SignaTrust document signing API",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "signatrust-mcp-server": "dist/server.js",
    "mcp-server": "dist/server.js"
  },
  "files": [
    "dist",
    "manifest.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bundle": "npm run build && npx @anthropic-ai/mcpb pack .",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "smoke:published": "node scripts/smoke-published.mjs",
    "e2e": "npm run build && node scripts/e2e.mjs",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "signatrust",
    "mcp",
    "model-context-protocol",
    "document-signing",
    "blockchain",
    "ai-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SignaTrustDev/signatrust-mcp.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0"
  },
  "overrides": {
    "@hono/node-server": "^1.19.10",
    "hono": "^4.11.10"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.0.0",
    "typescript": "~5.9.3",
    "vitest": "^4.0.0"
  }
}
